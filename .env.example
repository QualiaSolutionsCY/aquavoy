# ── App ───────────────────────────────────────────────
# Public base URL of this app (used to build the OAuth redirect URI).
APP_BASE_URL=http://localhost:3000

# ── Microsoft Graph / OneDrive (delegated OAuth) ──────────
# Register an app at https://entra.microsoft.com → App registrations.
#  - Supported account types: choose "common" below to allow both
#    work/school AND personal Microsoft accounts.
#  - Add a Web redirect URI: ${APP_BASE_URL}/api/onedrive/callback
#  - Create a client secret (Certificates & secrets).
#  - API permissions (delegated): offline_access, User.Read, Files.ReadWrite.All
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "common" (work + personal) | "organizations" | "consumers" | a tenant GUID
MICROSOFT_TENANT_ID=common
# Space-separated delegated scopes. offline_access is REQUIRED for refresh tokens.
MICROSOFT_SCOPES=offline_access User.Read Files.ReadWrite.All Mail.ReadWrite Mail.Send

# ── OpenRouter (conversational AI) ────────────────────────
# All LLM calls route through OpenRouter. Ask Fawzi for a key.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# ── Supabase (token storage) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. NEVER expose to the client. Used to read/write OAuth tokens.
SUPABASE_SERVICE_ROLE_KEY=
